{
  "source": {
    "api_token": "YOUR_SOURCE_API_TOKEN",
    "scim_token": "YOUR_SOURCE_SCIM_TOKEN",
    "host": "qase.io",
    "ssl": true
  },
  "target": {
    "api_token": "YOUR_TARGET_API_TOKEN",
    "scim_token": "YOUR_TARGET_SCIM_TOKEN",
    "host": "your-enterprise-domain",
    "ssl": true
  },
  "users": {
    "migrate": true,
    "create": true,
    "inactive": false,
    "default": 1,
    "skip_creation_confirm": false
  },
  "groups": {
    "create": true
  },
  "options": {
    "preserve_ids": true,
    "mappings_file": "mappings.json",
    "skip_projects": [],
    "only_projects": ["ECSE", "DIS", "TDS"],
    "parallel_project_migration": true,
    "max_parallel_projects": 4
  }
}
